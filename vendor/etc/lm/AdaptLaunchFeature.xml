<?xml version="1.0" ?>
<!--
 HyperCore v4.0 — AdaptLaunchFeature.xml
 Qualcomm's ML-based adaptive app launch boost.
 
 Changes from stock:
   - SamplesRequired: 4 → 2 (learn app patterns in 2 launches instead of 4)
   - Samples: 300 → 150 (keep less history, adapt faster to usage changes)
   
 This means AdaptLaunch starts optimizing your frequently-used apps sooner.
 Stock needs 4 cold launches before it learns the pattern — we cut that in half.
-->
<Feature>
    <Name>AdaptLaunch</Name>
    <Libname>libadaptlaunch.so</Libname>
    <Configs>
        <Enable>1</Enable>
    </Configs>
    <Meters>
        <SamplesRequired>2</SamplesRequired>
        <Meter>
            <Name>VmRss</Name>
            <Triggers>
                <Trigger>
                    <Primary>true</Primary>
                    <AsyncId>VENDOR_HINT_FIRST_LAUNCH_BOOST</AsyncId>
                    <AsyncType>1</AsyncType>
                </Trigger>
                <Trigger>
                    <Primary>false</Primary>
                    <AsyncId>VENDOR_HINT_TAP_EVENT</AsyncId>
                </Trigger>
                <Trigger>
                    <Primary>true</Primary>
                    <AsyncId>VENDOR_HINT_APP_WORKLOAD_TYPE</AsyncId>
                </Trigger>
                <Trigger>
                    <Primary>true</Primary>
                    <AsyncId>VENDOR_HINT_ACTIVITY_START</AsyncId>
                </Trigger>
                <Trigger>
                    <Primary>true</Primary>
                    <AsyncId>VENDOR_HINT_ACTIVITY_RESUME</AsyncId>
                </Trigger>
                <Trigger>
                    <Primary>true</Primary>
                    <AsyncId>VENDOR_HINT_ACTIVITY_STOP</AsyncId>
                </Trigger>
                <Trigger>
                    <Primary>true</Primary>
                    <AsyncId>VENDOR_HINT_ACTIVITY_PAUSE</AsyncId>
                </Trigger>
            </Triggers>
            <Samples>150</Samples>
            <Fields>
                <Field>VmRss:</Field>
            </Fields>
        </Meter>
    </Meters>
    <SpuriousHintApps>
        <App>com.android.permissioncontroller</App>
    </SpuriousHintApps>
</Feature>
